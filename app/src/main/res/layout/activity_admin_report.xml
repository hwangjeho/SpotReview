<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_bg">

    <!-- Top Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_admin_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_admin_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/brand_dark"
            android:contentDescription="뒤로가기" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Control"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/brand_dark"
            app:layout_constraintStart_toEndOf="@id/btn_admin_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="-48dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Tab Buttons (Styled like dark pill buttons) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_admin_tabs_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="32dp"
        app:cardBackgroundColor="@color/brand_dark"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/layout_admin_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_manage_reviews"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="리뷰 관리"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_manage_users"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="유저 관리"
                android:textColor="@color/brand_yellow"
                android:textStyle="bold"
                app:cornerRadius="28dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- List View -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_admin_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layout_admin_tabs_card"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
