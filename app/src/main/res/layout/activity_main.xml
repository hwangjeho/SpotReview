<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_bg"
    tools:context=".MainActivity">

    <!-- Logged Out State -->
    <LinearLayout
        android:id="@+id/layout_logged_out"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center"
        android:visibility="visible">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardBackgroundColor="@color/brand_yellow"
            app:strokeWidth="0dp"
            android:layout_marginBottom="32dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_compass"
                android:padding="24dp"
                app:tint="@color/brand_dark" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spot Review"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/brand_dark"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find your perfect spot and \nshare honest reviews"
            android:textSize="16sp"
            android:textColor="@color/brand_gray"
            android:layout_marginBottom="48dp"
            android:textAlignment="center"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_main_login"
            style="@style/Widget.SpotReview.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="로그인"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/brand_dark"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_main_register"
            style="@style/Widget.SpotReview.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="회원가입"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/brand_yellow"
            android:textColor="@color/brand_dark"/>
    </LinearLayout>

    <!-- Logged In State -->
    <LinearLayout
        android:id="@+id/layout_logged_in"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_welcome_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Let's Find \nPerfect Spot"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:lineHeight="36sp"
                    android:textColor="@color/brand_dark"/>

                <TextView
                    android:id="@+id/tv_user_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="일반 회원"
                    android:textSize="12sp"
                    android:textColor="@color/brand_dark"
                    android:background="@color/brand_yellow"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:strokeWidth="0dp"
                app:cardElevation="0dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:background="@color/brand_light_gray"
                    android:padding="12dp"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_explore_map"
            style="@style/Widget.SpotReview.Button"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:text="🗺️ 주변 명소 탐색하기"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="@color/brand_yellow"
            android:textColor="@color/brand_dark"
            android:layout_marginBottom="32dp"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔥 실시간 인기 명소"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/brand_dark"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_spot_ranking"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_main_logout"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="로그아웃"
            android:textColor="@color/status_red"
            android:layout_marginBottom="8dp"/>
    </LinearLayout>
</FrameLayout>
